{
  "expo": {
    "name": "Family Biographer",
    "slug": "family-biographer",
    "scheme": "familybiographer",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FBF8F3",
    "ios": {
      "bundleIdentifier": "com.familybiographer.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Family Biographer records your voice while you tell your life story, so it can be kept for your family.",
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Family Biographer records your voice while you tell your life story, so it can be kept for your family."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "764468b1-6292-4ef6-b51c-e1477213d3ca"
      }
    }
  }
}
